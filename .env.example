# ============================================================================
# Wealth Advisory Workbench — local stack configuration
# Copy to `.env` (git-ignored) and adjust as needed: `cp .env.example .env`
# Every port/credential below is consumed by docker-compose.yml.
# ============================================================================

# Compose project name → prefixes container & volume names (avoids clashes).
COMPOSE_PROJECT_NAME=wealth

# --- Postgres (+ pgvector) ---------------------------------------------------
POSTGRES_USER=wealth
POSTGRES_PASSWORD=wealth
POSTGRES_DB=wealth
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_PORT=6379

# --- MinIO (S3-compatible object store) --------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket bootstrapped by the backend on startup (TASK-005).
MINIO_BUCKET=wealth

# --- pgAdmin -----------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@wealth.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# --- MailHog (email-draft handoff testing, MSG9) -----------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
# App-facing SMTP port inside compose network (mailhog:1025). Override only if
# the container's internal SMTP port ever changes (extremely unlikely).
MAILHOG_CONTAINER_SMTP_PORT=1025

# --- Workbook data directory (TASK-008/009 loaders) -------------------------
# Path to the directory containing the two .xlsx workbooks. The container
# default (/app/data) is correct when running via docker compose. Override on
# the host: WEALTH_DATA_DIR=/absolute/path/to/SIX-Noumena-NTT-Data/data
WEALTH_DATA_DIR=/app/data

# --- Backend (FastAPI) — TASK-002 --------------------------------------------
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# CORS origins (comma-separated); Vite dev server (TASK-003) defaults to 5173.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# DB/Redis hostnames inside the compose network = service names (leave as-is).
POSTGRES_HOST=postgres
REDIS_HOST=redis

# --- Frontend (React + Vite) — TASK-003 --------------------------------------
# Host-published port for the Vite dev server (container always serves on 5173).
FRONTEND_PORT=5173
# Browser → backend base URL. The frontend runs in the browser (on the host), so
# this must be the host-published backend port, not the in-network service name.
# Must also appear in CORS_ORIGINS above.
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# Provider secrets (TASK-006). Names mirror demo/.env.example so the same
# hackathon credentials drop straight in. Every key below is OPTIONAL at boot:
# a missing one logs a warning and disables that one feature — it never crashes
# the app. Leave a key blank to run that capability degraded.
# ============================================================================

# --- LLM (OpenAI-compatible; §20 ST1 provider abstraction) — TASK-012 --------
# Active backend: ollama | openrouter | phoeniqs. Only the selected provider's
# key is required; the local Ollama path is keyless (fully private).
LLM_PROVIDER=ollama
# Ollama (local, fully private — production/privacy path):
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=gemma3:12b
OLLAMA_EMBED_MODEL=nomic-embed-text
# OpenRouter (hosted open-source, for VRAM-limited dev/demo):
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-3-12b-it
# Phoeniqs (provided credits / fallback):
PHOENIQS_API_KEY=
PHOENIQS_API_URL=https://maas.phoeniqs.com/v1
PHOENIQS_MODEL=inference-gpt-oss-120b

# --- SIX Financial Data (MCP server, external) — TASK-013 --------------------
SIX_MCP_TOKEN=
SIX_MCP_URL=https://ca-mcpwebapi-tools.nicepebble-599ed11f.westeurope.azurecontainerapps.io/mcp

# --- News = Event Registry / newsapi.ai (REST) — TASK-014 --------------------
NEWSAPI_KEY=
NEWSAI_API_URL=https://eventregistry.org/api/v1
