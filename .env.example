# ============================================================================
# Wealth Advisory Workbench — local stack configuration
# Copy to `.env` (git-ignored) and adjust as needed: `cp .env.example .env`
# Every port/credential below is consumed by docker-compose.yml.
# ============================================================================

# Compose project name → prefixes container & volume names (avoids clashes).
COMPOSE_PROJECT_NAME=wealth

# --- Postgres (+ pgvector) ---------------------------------------------------
POSTGRES_USER=wealth
POSTGRES_PASSWORD=wealth
POSTGRES_DB=wealth
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_PORT=6379

# --- MinIO (S3-compatible object store) --------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket bootstrapped by the backend on startup (TASK-005).
MINIO_BUCKET=wealth

# --- pgAdmin -----------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@wealth.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# --- MailHog (email-draft handoff testing, MSG9) -----------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
# App-facing SMTP port inside compose network (mailhog:1025). Override only if
# the container's internal SMTP port ever changes (extremely unlikely).
MAILHOG_CONTAINER_SMTP_PORT=1025

# --- Outbound email → RM (proactive dispatch, EPIC-08) -----------------------
# The ONLY outbound transport, and it targets the RM ONLY — never a client
# (autonomy boundary G1). Disabled (logged no-op) unless BOTH SMTP_HOST and
# RM_EMAIL are set. For local dev, point SMTP_HOST at the MailHog container so RM
# alerts land in the MailHog UI (http://localhost:${MAILHOG_UI_PORT}).
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sixease@localhost
SMTP_STARTTLS=false
# RM recipient for all proactive alerts/digests. Blank = dispatch is a no-op.
RM_EMAIL=

# --- Proactive radar dispatch (EPIC-08) --------------------------------------
# Background loop: critical Change-Radar items push instantly (SSE + RM email),
# the rest roll into one daily digest. Times are UTC.
RADAR_DISPATCH_ENABLED=true
RADAR_DISPATCH_INTERVAL=60       # poll cycle, seconds
RADAR_CRITICAL_MAGNITUDE=0.9     # >= this impact → instant push (else digest)
RADAR_REBROADCAST_MARGIN=0.5     # re-notify only if impact climbs 50%+ over last
RADAR_DIGEST_HOUR=7              # UTC hour the daily digest is sent
RADAR_DIGEST_LIMIT=10            # max items per digest
RADAR_QUIET_START=22             # quiet hours start (no instant emails; SSE still fires)
RADAR_QUIET_END=7               # quiet hours end (wrap-around midnight supported)

# --- Workbook data directory (TASK-008/009 loaders) -------------------------
# Path to the directory containing the two .xlsx workbooks. The container
# default (/app/data) is correct when running via docker compose. Override on
# the host: WEALTH_DATA_DIR=/absolute/path/to/SIX-Noumena-NTT-Data/data
WEALTH_DATA_DIR=/app/data

# --- Backend (FastAPI) — TASK-002 --------------------------------------------
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# CORS origins (comma-separated); Vite dev server (TASK-003) defaults to 5173.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# DB/Redis hostnames inside the compose network = service names (leave as-is).
POSTGRES_HOST=postgres
REDIS_HOST=redis

# --- Frontend (React + Vite) — TASK-003 --------------------------------------
# Host-published port for the Vite dev server (container always serves on 5173).
FRONTEND_PORT=5173
# Browser → backend base URL. The frontend runs in the browser (on the host), so
# this must be the host-published backend port, not the in-network service name.
# Must also appear in CORS_ORIGINS above.
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# Provider secrets (TASK-006). Names mirror demo/.env.example so the same
# hackathon credentials drop straight in. Every key below is OPTIONAL at boot:
# a missing one logs a warning and disables that one feature — it never crashes
# the app. Leave a key blank to run that capability degraded.
# ============================================================================

# --- LLM (OpenAI-compatible; §20 ST1 provider abstraction) — TASK-012 --------
# Active backend: ollama | openrouter | phoeniqs. Only the selected provider's
# key is required; the local Ollama path is keyless (fully private).
LLM_PROVIDER=ollama
# Ollama (local, fully private — production/privacy path):
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=gemma3:12b
OLLAMA_EMBED_MODEL=nomic-embed-text
# OpenRouter (hosted open-source, for VRAM-limited dev/demo):
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-3-12b-it
# Phoeniqs (provided credits / fallback):
PHOENIQS_API_KEY=
PHOENIQS_API_URL=https://maas.phoeniqs.com/v1
PHOENIQS_MODEL=inference-gpt-oss-120b
# Whisper speech-to-text for voice notes (decoupled from LLM_PROVIDER).
#   WHISPER_PROVIDER=local    → faster-whisper-server container on the GPU (default)
#   WHISPER_PROVIDER=phoeniqs → hosted Whisper on Phoeniqs (uses PHOENIQS_API_KEY)
WHISPER_PROVIDER=local
WHISPER_BASE_URL=http://whisper:8000/v1
WHISPER_MODEL=Systran/faster-whisper-large-v3
WHISPER_PORT=18001
# Used only when WHISPER_PROVIDER=phoeniqs (~0.006 credits/min of audio):
PHOENIQS_WHISPER_MODEL=inference-whisper-large-v3

# --- SIX Financial Data (MCP server, external) — TASK-013 --------------------
SIX_MCP_TOKEN=
SIX_MCP_URL=https://ca-mcpwebapi-tools.nicepebble-599ed11f.westeurope.azurecontainerapps.io/mcp

# --- News = Event Registry / newsapi.ai (REST) — TASK-014 --------------------
NEWSAPI_KEY=
NEWSAI_API_URL=https://eventregistry.org/api/v1

# --- Microsoft Graph (email transport, optional) — TASK-060/061 --------------
# SCOPED EXCEPTION to the "no Azure" rule: used ONLY as an email transport. The
# four credentials below come from the Azure app registration; MS_GRAPH_MAILBOX is
# the SHARED mailbox UPN/address the app reads from and sends through.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_MAILBOX=
# Optional — sensible defaults; override only for sovereign/national clouds.
MS_GRAPH_AUTHORITY=https://login.microsoftonline.com
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
#
# Auth mode:
#   app       → client-credentials, app-only (read-only inbound; needs an Exchange
#               mailbox + Application Mail.Read + admin consent).
#   delegated → web "Sign in with Microsoft" (auth-code + PKCE). The RM signs in
#               with their OWN account and reads/sends through the shared mailbox
#               (Delegated Mail.Read.Shared / Mail.Send.Shared; RM granted access
#               to the shared mailbox in Exchange). This is the TASK-061 path.
MS_GRAPH_AUTH_MODE=delegated
# Must EXACTLY match a Redirect URI (type: Web) on the Azure app registration.
MS_GRAPH_REDIRECT_URI=http://localhost:8000/auth/ms/callback
# Delegated scopes (comma-separated). MSAL adds openid/profile/offline_access itself.
# Calendars.ReadWrite enables note→calendar write-back (TASK-062 Part B); drop it if
# you don't grant that permission in Azure.
MS_GRAPH_SCOPES=Mail.Read.Shared,Mail.Send.Shared,Calendars.ReadWrite
# Where the callback returns the browser after sign-in (defaults to first CORS origin).
MS_GRAPH_POST_LOGIN_REDIRECT=http://localhost:5173
# Allow proactive RM alerts to send via Graph (shared mailbox → RM) instead of SMTP.
MS_GRAPH_SEND_ENABLED=false
# Timezone (IANA) for calendar events created from voice notes.
MS_GRAPH_CALENDAR_TIMEZONE=Europe/Zurich

# --- Email auto-draft (TASK-062 Part A) --------------------------------------
# When a NEW inbound email hits the radar, the agent pre-drafts the answer (a reply
# for correspondence, an advisory for a holding) for RM review — draft only, never
# sent (G1). Set false to keep emails on the radar without auto-drafting.
EMAIL_AUTODRAFT_ENABLED=true
EMAIL_AUTODRAFT_MAX_PER_CYCLE=3

# --- Demo scenario (pitch only) ----------------------------------------------
# Pre-bakes the "overnight client email → prepared answer" beat (Change Radar item
# + DONE task + drafted reply) with no live inbox / sign-in, anchored to a persona.
# Trigger instantly via POST /admin/seed/demo/divorce; reset via .../reset.
DEMO_EMAIL_ENABLED=false
DEMO_EMAIL_CLIENT=Julian Ammann
